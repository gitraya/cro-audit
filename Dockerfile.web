# Dockerfile for the CRO audit Next.js web app.
#
# Multi-stage build that produces a small runtime image from Next.js'
# standalone output (requires `output: "standalone"` in next.config.ts).
#
# NOTE: NEXT_PUBLIC_* values are inlined into the client bundle at BUILD time,
# so they must be passed as build args (Coolify: "Build Variables"), not just
# as runtime env vars. Server-only secrets (GEMINI_API_KEY, PAGESPEED_API_KEY,
# SUPABASE_SERVICE_ROLE_KEY) are read at runtime and set as normal env vars.

FROM node:22-alpine AS deps
WORKDIR /app
# Install all deps (incl. dev) — the build needs next, tailwind, typescript.
COPY package.json package-lock.json ./
RUN npm ci

FROM node:22-alpine AS builder
WORKDIR /app

# Build-time public config. Coolify injects these via Build Variables.
ARG NEXT_PUBLIC_SUPABASE_URL
ARG NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
ENV NEXT_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL
ENV NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=$NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
ENV NEXT_TELEMETRY_DISABLED=1

COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN npm run build

FROM node:22-alpine AS runner
WORKDIR /app

# tini reaps zombies and forwards signals cleanly — Coolify runs without --init.
RUN apk add --no-cache tini

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# Standalone output: server.js + minimal traced node_modules, plus static assets.
COPY --from=builder /app/public ./public
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static

USER node
EXPOSE 3000

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["node", "server.js"]
